# Public — safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER prefix this with NEXT_PUBLIC_: it bypasses RLS
# entirely and must never reach the browser bundle (see ADR-003,
# /supabase/policies/README.md, /web/lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. The Claude proxy (/web/app/api/ai/turn) holds this; it must
# never reach the browser bundle or the extension (ADR-008, locked key policy).
ANTHROPIC_API_KEY=

# Dev-only note: email confirmation is off in the Supabase Auth dashboard
# (Authentication > Providers > Email > "Confirm email") for the hosted
# "calyxa" project, so signup is testable without SMTP. Re-enable before
# launch — there is no MCP tool to toggle this, it must be flipped by hand.

# Dev-only note: the extension's background worker (extension/src/lib/api.ts)
# targets this server at http://localhost:3000 via a hardcoded API_BASE
# constant, not an env var — the extension holds no secret to gate behind
# one. No action needed here; this just documents the matching value.
